{
  "name": "cloud-photo-platform",
  "version": "0.1.0",
  "private": true,
  "description": "云相册系统 — 融合高性能桌面体验与云端存储",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "clean": "turbo clean",
    "test": "turbo test",
    "test:e2e": "pnpm --filter @cloud-photo/e2e test",
    "test:e2e:server": "pnpm --filter @cloud-photo/e2e test:server",
    "test:e2e:desktop": "pnpm --filter @cloud-photo/e2e test:desktop"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "@types/node": "^22.14.0"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["better-sqlite3", "esbuild", "electron", "electron-winstaller"]
  },
  "packageManager": "pnpm@10.9.0",
  "engines": {
    "node": ">=18.0.0"
  }
}
