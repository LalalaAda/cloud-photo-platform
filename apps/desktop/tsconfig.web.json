{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "outDir": "./out",
    "rootDir": "./src/renderer/src",
    "tsBuildInfoFile": "./out/tsconfig.web.tsbuildinfo",
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "types": ["vite/client"],
    "paths": {
      "@/*": ["./src/renderer/src/*"]
    }
  },
  "include": [
    "src/renderer/src/**/*.ts",
    "src/renderer/src/**/*.tsx"
  ]
}
